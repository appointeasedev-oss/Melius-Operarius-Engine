modules = ["python-3.11"]
[nix]
channel = "stable-25_05"
packages = ["unzip"]

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Melius Operarius Engine"

[[workflows.workflow]]
name = "Melius Operarius Engine"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python melius-engine-new-main/melius-engine/agent.py"

[workflows.workflow.metadata]
outputType = "console"
